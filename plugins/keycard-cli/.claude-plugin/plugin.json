{
  "name": "keycard-cli",
  "description": "A plugin to integrate the Keycard CLI with Claude Code.",
  "hooks": {
    "SessionStart": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "keycard agent hook --claude"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "keycard agent hook --claude"
          }
        ]
      }
    ]
  },
  "version": "0.1.0"
}
